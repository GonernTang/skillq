# mg/.env.example — copy to .env and fill in.
# Same shape as lqrl's .env.example; mg re-uses the same env vars
# (lqrl reads OPENAI_*/ANTHROPIC_*/CODEX_* via the skills_vote package,
# and mg reads them via python-dotenv in its own CLI).

# --- Codex / OpenAI path (for SkillsVoteCodex) -------------------
OPENAI_BASE_URL=
OPENAI_API_KEY=
CODEX_FORCE_API_KEY=1

# --- Claude / Anthropic path (for SkillsVoteClaudeCode) ---------
# Use ANTHROPIC_API_KEY for the official Anthropic endpoint.
ANTHROPIC_API_KEY=
# Use ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN + ANTHROPIC_MODEL
# when proxying through a custom endpoint (e.g. DeepSeek, Moonshot).
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=
