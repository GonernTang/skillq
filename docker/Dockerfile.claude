ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# Claude Code uses Node.js, so we still need NVM
ARG NVM_VERSION=v0.40.4
ARG NODE_VERSION=22
ARG CLAUDE_VERSION=latest

ENV NVM_DIR=/opt/nvm
ENV BASH_ENV=/etc/profile.d/nvm.sh
ENV PATH=/usr/local/bin:/root/.local/bin:/opt/nvm/current/bin:${PATH}

RUN set -eu; \
    if ldd --version 2>&1 | grep -qi musl || [ -f /etc/alpine-release ]; then \
        apk add --no-cache curl bash nodejs npm ripgrep; \
    elif command -v apt-get >/dev/null 2>&1; then \
        apt-get update && apt-get install -y curl ripgrep; \
    elif command -v yum >/dev/null 2>&1; then \
        yum install -y curl ripgrep; \
    else \
        echo "Warning: No known package manager found, assuming curl is available" >&2; \
    fi

RUN set -eu; \
    claude_pkg="@anthropic-ai/claude-code@${CLAUDE_VERSION}"; \
    if ! ldd --version 2>&1 | grep -qi musl && [ ! -f /etc/alpine-release ]; then \
        bash -lc ' \
            set -euo pipefail; \
            mkdir -p "$NVM_DIR"; \
            curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" | PROFILE=/dev/null NVM_DIR="$NVM_DIR" bash; \
            . "$NVM_DIR/nvm.sh"; \
            nvm install "$NODE_VERSION"; \
            nvm alias default "$NODE_VERSION"; \
            nvm use "$NODE_VERSION"; \
            node_dir="$NVM_DIR/versions/node/$(nvm version "$NODE_VERSION")"; \
            ln -sfn "$node_dir" "$NVM_DIR/current"; \
            printf "%s\n" \
                "export NVM_DIR=/opt/nvm" \
                "[ -s \"\$NVM_DIR/nvm.sh\" ] && . \"\$NVM_DIR/nvm.sh\"" \
                > /etc/profile.d/nvm.sh; \
            mkdir -p /usr/local/bin /root/.local/bin; \
            for bin in node npm npx claude; do \
                ln -sf "$node_dir/bin/$bin" "/usr/local/bin/$bin"; \
                ln -sf "$node_dir/bin/$bin" "/root/.local/bin/$bin"; \
            done \
        '; \
    fi; \
    npm -v; \
    npm install -g "$claude_pkg"; \
    mkdir -p /root/.local/bin; \
    ln -sf /usr/local/bin/claude /root/.local/bin/claude; \
    claude --version; \
    # Preinstall uv 0.9.5 so the task verifier (test.sh) doesn't have to \
    # download it at runtime — verifier test scripts that run 'curl | sh' to \
    # install uv are flaky in offline / restricted-network environments. \
    curl -LsSf https://astral.sh/uv/0.9.5/install.sh | sh; \
    ln -sf /root/.local/bin/uv /usr/local/bin/uv; \
    ln -sf /root/.local/bin/uvx /usr/local/bin/uvx; \
    uv --version; \
    # uv 0.9.5 no longer writes $HOME/.local/bin/env, but most \
    # Terminal-Bench test.sh scripts still `source $HOME/.local/bin/env` \
    # on line 10. Install a tiny shim so that source call succeeds. \
    printf '#!/bin/sh\nexport PATH="$HOME/.local/bin:$PATH"\n' \
        > /root/.local/bin/env && chmod +x /root/.local/bin/env; \
    # Preinstall cpython-3.13 standalone so `uvx -p 3.13 ...` (used by 82/89 \
    # Terminal-Bench test.sh scripts) does not have to download it at \
    # verifier runtime. The github.com download is the dominant verifier \
    # failure mode in restricted-network WSL2 environments. \
    uv python install 3.13; \
    uv python list --only-installed
